# --- App ---
ENVIRONMENT=development
APP_NAME=Nakshatra Nexus API
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173

# --- MongoDB ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_DB_NAME=nakshatra_nexus

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Gemini ---
GEMINI_API_KEY=

# --- FLUX / Stable Diffusion (avatar generation) ---
FLUX_API_KEY=
FLUX_API_URL=https://api.together.xyz/v1/images/generations

# --- Resend (email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Nakshatra Nexus <noreply@yourdomain.com>

# --- Security ---
SECRET_KEY=changeme-super-secret
